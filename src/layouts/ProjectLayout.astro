---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'work'>;
}

const { project } = Astro.props;
const { title, description, date, tags, image, link } = project.data;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
});
---

<BaseLayout title={title} description={description}>
  <article class="mx-auto max-w-3xl px-6 py-16">
    <header class="mb-12">
      <div class="flex items-center gap-3 text-sm text-gray-500 mb-4">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        {tags.length > 0 && (
          <>
            <span>·</span>
            <div class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <span class="px-2 py-1 bg-gray-100 text-gray-600 rounded text-xs">
                  {tag}
                </span>
              ))}
            </div>
          </>
        )}
      </div>
      <h1 class="text-4xl font-bold text-gray-900 leading-tight">
        {title}
      </h1>
      {description && (
        <p class="mt-4 text-xl text-gray-600">
          {description}
        </p>
      )}
      {link && (
        <a
          href={link}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 mt-6 text-blue-600 hover:underline"
        >
          View project
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      )}
    </header>
    {image && (
      <img
        src={image}
        alt={title}
        class="w-full rounded-lg mb-12 border border-gray-100"
      />
    )}
    <div class="prose prose-gray max-w-none prose-headings:font-semibold prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline">
      <slot />
    </div>
    <footer class="mt-16 pt-8 border-t border-gray-100">
      <a href="/work" class="text-blue-600 hover:underline">
        &larr; Back to all work
      </a>
    </footer>
  </article>
</BaseLayout>
