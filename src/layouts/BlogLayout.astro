---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, date, tags } = post.data;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <article class="mx-auto max-w-[900px] px-6 py-16">
    <header class="mb-12">
      <div class="flex items-center gap-3 text-sm text-[#555555] mb-4">
        <time datetime={date.toISOString()} class="font-mono">{formattedDate}</time>
        {tags.length > 0 && (
          <>
            <span>·</span>
            <div class="flex gap-2">
              {tags.map((tag) => (
                <span class="text-[#555555]">#{tag}</span>
              ))}
            </div>
          </>
        )}
      </div>
      <h1 class="text-3xl font-light tracking-tight text-[#f0f0f0] leading-tight">
        {title}
      </h1>
      {description && (
        <p class="mt-4 text-lg text-[#888888]">
          {description}
        </p>
      )}
    </header>
    <div class="prose prose-invert max-w-none prose-headings:font-light prose-headings:tracking-tight prose-a:text-[#60A5FA] prose-a:no-underline hover:prose-a:underline prose-code:text-[#60A5FA] prose-pre:bg-[#141414] prose-pre:border prose-pre:border-[#222222]">
      <slot />
    </div>
    <footer class="mt-16 pt-8 border-t border-[#222222]">
      <a href="/blog" class="text-[#60A5FA] hover:opacity-80 transition-opacity">
        &larr; Back to all posts
      </a>
    </footer>
  </article>
</BaseLayout>
