---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="mx-auto max-w-4xl px-6 py-24 md:py-32">
  <h1 class="text-4xl md:text-5xl font-bold text-gray-900 leading-tight">
    {title}
  </h1>
  {subtitle && (
    <p class="mt-6 text-xl text-gray-600 max-w-2xl">
      {subtitle}
    </p>
  )}
  <slot />
</section>
