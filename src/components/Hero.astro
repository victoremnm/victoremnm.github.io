---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="mx-auto max-w-4xl px-6 py-24 md:py-32 gxsc-reveal">
  <h1 class="text-4xl md:text-5xl font-semibold text-[var(--color-text-primary)] leading-tight font-display">
    {title}
  </h1>
  {subtitle && (
    <p class="mt-6 text-xl text-[var(--color-text-secondary)] max-w-2xl gxsc-reveal gxsc-delay-1">
      {subtitle}
    </p>
  )}
  <slot />
</section>
