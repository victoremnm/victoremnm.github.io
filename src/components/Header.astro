---
const navLinks = [
  { href: '/about', label: 'About' },
  { href: '/blog', label: 'Writing' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-[#222222] bg-[#0a0a0a]/90 backdrop-blur-md">
  <nav class="mx-auto max-w-[900px] px-6 py-4 flex items-center justify-between">
    <a href="/" class="text-base font-medium tracking-tight text-[#f0f0f0] hover:text-[#60A5FA] transition-colors">
      victorem
    </a>
    <ul class="flex items-center gap-8">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'text-xs uppercase tracking-widest font-medium transition-colors',
              currentPath === link.href || currentPath.startsWith(link.href + '/')
                ? 'text-[#60A5FA]'
                : 'text-[#888888] hover:text-[#60A5FA]',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<!-- Spacer for fixed header -->
<div class="h-14"></div>
