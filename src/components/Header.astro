---
const navLinks = [
  { href: '/work', label: 'Work' },
  { href: '/blog', label: 'Essays' },
  { href: '/logs', label: 'Logs' },
  { href: '/resources', label: 'Wiki' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-bg-primary)]">
  <nav class="mx-auto max-w-[900px] px-6 py-4 flex items-center justify-between">
    <a href="/" class="text-base font-medium tracking-tight text-[var(--color-text-primary)] hover:text-[var(--color-accent)] transition-colors">
      victorem
    </a>
    <div class="flex items-center gap-6">
      <ul class="flex items-center gap-8">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'text-xs uppercase tracking-widest font-medium transition-colors',
              currentPath === link.href || currentPath.startsWith(link.href + '/')
                ? 'text-[var(--color-accent)]'
                : 'text-[var(--color-text-muted)] hover:text-[var(--color-accent)]',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
      </ul>
      <button class="theme-toggle mono" type="button" data-theme-toggle aria-label="Toggle color theme">
        Light
      </button>
    </div>
  </nav>
</header>

<!-- Spacer for fixed header -->
<div class="h-14"></div>
