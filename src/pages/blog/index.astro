---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Technical Essays" description="Deep-dives into systems, post-mortems, and technical experiments.">
  <div class="mx-auto max-w-[900px] px-6 py-16 gxsc-reveal">
    <h1 class="text-3xl font-light tracking-tight text-[var(--color-text-primary)] mb-4 font-display">Technical Essays</h1>
    <p class="text-lg text-[var(--color-text-secondary)] mb-12 gxsc-reveal gxsc-delay-1 max-w-2xl">
      Detailed explorations of engineering systems, retrospective post-mortems, and technical experiments.
    </p>

    <div class="section-header gxsc-reveal gxsc-delay-2">All Essays</div>

    {allPosts.length > 0 ? (
      <div class="space-y-3 gxsc-reveal gxsc-delay-3">
        {allPosts.map((post) => (
          <a href={`/blog/${post.slug}`} class="card card-accent block p-5 group">
            <div class="flex items-center justify-between gap-4">
              <div class="flex-1 min-w-0">
                <h2 class="text-base font-medium text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors truncate">
                  {post.data.title}
                </h2>
                <p class="mt-1 text-sm text-[var(--color-text-muted)] truncate">
                  {post.data.description}
                </p>
              </div>
              <time
                datetime={post.data.date.toISOString()}
                class="text-xs font-mono text-[var(--color-text-muted)] whitespace-nowrap"
              >
                {post.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-[var(--color-text-muted)]">No posts yet. Check back soon!</p>
    )}
  </div>
</BaseLayout>
