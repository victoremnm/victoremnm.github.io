---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allResources = (await getCollection('resources', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Resources" description="Technical guides and reference material">
  <div class="mx-auto max-w-[900px] px-6 py-16 gxsc-reveal">
    <h1 class="text-3xl font-light tracking-tight text-[var(--color-text-primary)] mb-4 font-display">Resources</h1>
    <p class="text-lg text-[var(--color-text-secondary)] mb-12 gxsc-reveal gxsc-delay-1">
      Technical guides, frameworks, and reference material.
    </p>

    {allResources.length > 0 ? (
      <div class="space-y-3 gxsc-reveal gxsc-delay-2">
        {allResources.map((resource) => (
          <a href={`/resources/${resource.slug}`} class="card card-accent block p-5 group">
            <div class="flex items-center justify-between gap-4">
              <div class="flex-1 min-w-0">
                <h2 class="text-base font-medium text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors">
                  {resource.data.title}
                </h2>
                <p class="mt-1 text-sm text-[var(--color-text-muted)] line-clamp-1">
                  {resource.data.description}
                </p>
              </div>
              <div class="flex gap-2">
                {resource.data.tags.slice(0, 2).map((tag) => (
                  <span class="text-xs font-mono text-[var(--color-text-muted)]">#{tag}</span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-[var(--color-text-muted)]">No resources yet.</p>
    )}
  </div>
</BaseLayout>
