---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with Victor">
  <div class="mx-auto max-w-[900px] px-6 py-16 gxsc-reveal">
    <h1 class="text-3xl font-light tracking-tight text-[var(--color-text-primary)] mb-4 font-display">Contact</h1>
    <p class="text-lg text-[var(--color-text-secondary)] mb-12 gxsc-reveal gxsc-delay-1">
      I'd love to hear from you. Whether you have a question, want to collaborate,
      or just want to say hello  -  reach out.
    </p>

    <div class="space-y-10 gxsc-reveal gxsc-delay-2">
      <section>
        <h2 class="section-header">Email</h2>
        <a
          href="mailto:victorem@alumni.stanford.edu"
          class="text-[var(--color-accent)] hover:opacity-80 transition-opacity font-mono"
        >
          victorem@alumni.stanford.edu
        </a>
      </section>

      <section>
        <h2 class="section-header">Connect</h2>
        <div class="flex flex-col gap-3">
          <a
            href="https://github.com/victoremnm"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors"
          >
            GitHub →
          </a>
          <a
            href="https://linkedin.com/in/victorem"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors"
          >
            LinkedIn →
          </a>
          <a
            href="https://victoremnm.substack.com"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors"
          >
            Substack →
          </a>
        </div>
      </section>

      <section>
        <h2 class="section-header">Schedule a Chat</h2>
        <p class="text-[var(--color-text-secondary)] mb-4">
          Want to connect? Book some time on my calendar.
        </p>
        <a
          href="https://calendar.app.google/k8jxn3WuzzdaWhos6"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary"
        >
          Book a meeting
        </a>
      </section>

      <section>
        <h2 class="section-header">Resume</h2>
        <a
          href="/resume.pdf"
          target="_blank"
          class="text-[var(--color-accent)] hover:opacity-80 transition-opacity"
        >
          Download Resume (PDF) →
        </a>
      </section>
    </div>
  </div>
</BaseLayout>
