---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allWork = (await getCollection('work'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Work" description="A collection of projects and work">
  <div class="mx-auto max-w-4xl px-6 py-16 gxsc-reveal">
    <h1 class="text-4xl font-semibold text-[var(--color-text-primary)] mb-4 font-display">Work</h1>
    <p class="text-xl text-[var(--color-text-secondary)] mb-12 gxsc-reveal gxsc-delay-1">
      A selection of projects I've worked on. From side projects to professional work.
    </p>

    {allWork.length > 0 ? (
      <div class="grid gap-6 md:grid-cols-2 gxsc-reveal gxsc-delay-2">
        {allWork.map((project) => (
          <a
            href={`/work/${project.slug}`}
            class="group card card-accent block p-6 transition-all"
          >
            {project.data.image && (
              <img
                src={project.data.image}
                alt={project.data.title}
                class="w-full h-40 object-cover rounded-[10px] mb-4 border border-[var(--color-border)]"
              />
            )}
            <div class="flex items-center gap-2 mb-2">
              {project.data.featured && (
                <span class="px-2 py-0.5 bg-[var(--color-bg-primary)] text-[var(--color-accent)] rounded-full text-xs font-medium border border-[var(--color-border)]">
                  Featured
                </span>
              )}
              <time class="text-sm text-[var(--color-text-muted)]">
                {project.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                })}
              </time>
            </div>
            <h2 class="font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors">
              {project.data.title}
            </h2>
            <p class="mt-2 text-[var(--color-text-secondary)] text-sm">
              {project.data.description}
            </p>
            <div class="mt-4 flex flex-wrap gap-2">
              {project.data.tags.slice(0, 4).map((tag) => (
                <span class="px-2 py-1 bg-[var(--color-bg-primary)] text-[var(--color-text-muted)] rounded-full text-xs border border-[var(--color-border)]">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-[var(--color-text-muted)]">No projects yet. Check back soon!</p>
    )}
  </div>
</BaseLayout>
