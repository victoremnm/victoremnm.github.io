---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('work')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const title = 'Project Dashboard';
const description = 'A scan of active and completed engineering projects.';
---

<BaseLayout title={title} description={description}>
	<div class="space-y-12">
		<header class="space-y-4">
			<h1 class="text-4xl font-bold tracking-tight text-primary">{title}</h1>
			<p class="text-lg text-muted max-w-2xl">{description}</p>
		</header>

		<div class="grid gap-8">
			{projects.map((project) => (
				<div class="group relative flex flex-col items-start p-6 rounded-2xl border border-border bg-card hover:border-accent transition-all">
					<div class="flex items-center gap-3 mb-2">
						<span class:list={[
							'px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider',
							project.data.status === 'Active' ? 'bg-accent/10 text-accent border border-accent/20' : 
							project.data.status === 'Paused' ? 'bg-yellow-500/10 text-yellow-500 border border-yellow-500/20' :
							'bg-muted/10 text-muted border border-muted/20'
						]}>
							{project.data.status}
						</span>
						<span class="text-xs font-mono text-muted">
							{project.data.date.getFullYear()}
						</span>
					</div>
					
					<h2 class="text-xl font-bold text-primary mb-2 group-hover:text-accent transition-colors">
						<a href={`/work/${project.slug}`}>
							{project.data.title}
						</a>
					</h2>
					
					<p class="text-secondary text-sm leading-relaxed mb-4">
						{project.data.description}
					</p>
					
					{project.data.learning && (
						<div class="mt-auto w-full p-3 rounded-lg bg-primary/5 border border-border/50">
							<span class="text-[10px] font-bold uppercase tracking-widest text-muted block mb-1">Lesson Learned</span>
							<p class="text-xs italic text-primary/80">
								"{project.data.learning}"
							</p>
						</div>
					)}
					
					<div class="mt-4 flex flex-wrap gap-2">
						{project.data.tags.map(tag => (
							<span class="text-[10px] font-mono text-muted bg-muted/5 px-1.5 py-0.5 rounded">#{tag}</span>
						))}
					</div>
				</div>
			))}
		</div>
	</div>
</BaseLayout>
