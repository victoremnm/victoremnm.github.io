---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="mx-auto max-w-[900px] px-6 py-20 gxsc-reveal">
    <h1 class="text-4xl md:text-5xl font-light tracking-tight text-[var(--color-text-primary)] leading-tight mb-6 font-display">
      Victor Em's <br/><span class="text-[var(--color-accent)]">Technical Log</span>
    </h1>
    <p class="text-lg text-[var(--color-text-secondary)] max-w-xl leading-relaxed mb-8 gxsc-reveal gxsc-delay-1">
      This is a living archive of my engineering work, system designs, and daily learnings. 
      For my professional portfolio, visit <a href="https://victorem.me" class="text-[var(--color-accent)] hover:underline">victorem.me</a>.
    </p>
    <div class="flex flex-wrap gap-4 gxsc-reveal gxsc-delay-2">
      <a href="/logs" class="btn btn-primary">Read the Logs</a>
      <a href="/blog" class="btn btn-secondary">Read Essays</a>
    </div>
  </section>

  <!-- Experience -->
  <section class="mx-auto max-w-[900px] px-6 pb-16 gxsc-reveal gxsc-delay-1">
    <div class="section-header">Experience</div>
    <div class="space-y-0">
      <div class="grid grid-cols-[140px_1fr] gap-6 py-4 border-b border-[var(--color-border)]">
        <div class="font-mono text-sm text-[var(--color-text-muted)]">2025  -  Now</div>
        <div>
          <h3 class="text-base font-medium text-[var(--color-text-primary)]">Engineering Manager</h3>
          <div class="text-sm text-[var(--color-text-secondary)]">Stealth Crypto Startup</div>
        </div>
      </div>
      <div class="grid grid-cols-[140px_1fr] gap-6 py-4 border-b border-[var(--color-border)]">
        <div class="font-mono text-sm text-[var(--color-text-muted)]">2023  -  2025</div>
        <div>
          <h3 class="text-base font-medium text-[var(--color-text-primary)]">Staff Engineer, ML Platform</h3>
          <div class="text-sm text-[var(--color-text-secondary)]">SiriusXM</div>
        </div>
      </div>
      <div class="grid grid-cols-[140px_1fr] gap-6 py-4 border-b border-[var(--color-border)]">
        <div class="font-mono text-sm text-[var(--color-text-muted)]">2022  -  2023</div>
        <div>
          <h3 class="text-base font-medium text-[var(--color-text-primary)]">Senior Data Engineer</h3>
          <div class="text-sm text-[var(--color-text-secondary)]">Meta</div>
        </div>
      </div>
      <div class="grid grid-cols-[140px_1fr] gap-6 py-4 border-b border-[var(--color-border)]">
        <div class="font-mono text-sm text-[var(--color-text-muted)]">2019  -  2022</div>
        <div>
          <h3 class="text-base font-medium text-[var(--color-text-primary)]">Data Engineering Lead</h3>
          <div class="text-sm text-[var(--color-text-secondary)]">Disney Streaming</div>
        </div>
      </div>
      <div class="grid grid-cols-[140px_1fr] gap-6 py-4">
        <div class="font-mono text-sm text-[var(--color-text-muted)]">2016  -  2019</div>
        <div>
          <h3 class="text-base font-medium text-[var(--color-text-primary)]">Data Analyst / Data Scientist</h3>
          <div class="text-sm text-[var(--color-text-secondary)]">Foursquare</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Writing -->
  {recentPosts.length > 0 && (
    <section class="mx-auto max-w-[900px] px-6 pb-24 gxsc-reveal gxsc-delay-2">
      <div class="section-header">Writing</div>
      <div class="space-y-3">
        {recentPosts.map((post) => (
          <a href={`/blog/${post.slug}`} class="card card-accent block p-5 group">
            <div class="flex items-center justify-between gap-4">
              <h3 class="text-base font-medium text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors">
                {post.data.title}
              </h3>
              <time
                datetime={post.data.date.toISOString()}
                class="text-xs font-mono text-[var(--color-text-muted)] whitespace-nowrap"
              >
                {post.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
            </div>
          </a>
        ))}
      </div>
      <div class="mt-6">
        <a href="/blog" class="text-[var(--color-accent)] hover:opacity-80 transition-opacity text-sm">
          Read all posts →
        </a>
      </div>
    </section>
  )}
</BaseLayout>
