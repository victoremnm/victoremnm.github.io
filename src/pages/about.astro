---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="Learn more about Victor and his background">
  <div class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="text-4xl font-bold text-gray-900 mb-8">About</h1>

    <div class="prose prose-gray max-w-none">
      <p class="text-xl text-gray-600 mb-8">
        I'm Victor — a builder, coach, and lifelong learner based in [Your Location].
      </p>

      <h2>What I Do</h2>
      <p>
        By day, I work on [describe your primary work]. I'm passionate about
        [technologies/domains you care about] and enjoy tackling complex problems
        that require both technical depth and creative thinking.
      </p>

      <h2>Coaching</h2>
      <p>
        Beyond building, I help people [describe your coaching focus]. Whether it's
        [specific areas], I believe in [your coaching philosophy].
      </p>

      <h2>Background</h2>
      <p>
        [Brief career/education history. What led you here? Key experiences that shaped you.]
      </p>

      <h2>When I'm Not Working</h2>
      <p>
        You'll find me [hobbies, interests, what you do for fun].
      </p>
    </div>

    <div class="mt-12 pt-8 border-t border-gray-100">
      <p class="text-gray-600 mb-4">Want to work together or just say hi?</p>
      <a
        href="/contact"
        class="inline-block px-6 py-3 bg-gray-900 text-white rounded-lg font-medium hover:bg-gray-800 transition-colors"
      >
        Get in touch
      </a>
    </div>
  </div>
</BaseLayout>
